{
  "name": "insight-vault",
  "version": "0.1.0",
  "description": "InsightVault — trợ lý tri thức cục bộ (local-first) trên desktop",
  "author": "hoanghainh1188",
  "license": "MIT",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run lint && electron-vite build",
    "start": "electron-vite preview",
    "lint": "prettier --check \"src/**/*.{ts,tsx,css}\" \"tests/**/*.ts\" && eslint . && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac dmg",
    "dist:win": "electron-vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.31.0",
    "@mozilla/readability": "^0.6.0",
    "@tanstack/react-query": "^5.59.0",
    "apache-arrow": "18.1.0",
    "electron-store": "^8.2.0",
    "jsdom": "^29.1.1",
    "keytar": "^7.9.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.4",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
